generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
  VIEWER
}

enum UpdateStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  FINALIZED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  HALF_DAY
  REMOTE
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         Role          @default(MEMBER)
  displayOrder Int           @default(0)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  dailyUpdates  DailyUpdate[]
  adminNotes    AdminNote[]      @relation("AdminNoteCreator")
  attendances   Attendance[]
  activityLogs  ActivityLog[]
  notifications Notification[]

  @@map("users")
}

model DailyUpdate {
  id        String       @id @default(cuid())
  userId    String
  date      DateTime     @db.Date
  status    UpdateStatus @default(DRAFT)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     DailyTask[]
  adminNotes AdminNote[]

  @@unique([userId, date])
  @@index([date])
  @@index([userId])
  @@map("daily_updates")
}

model DailyTask {
  id            String      @id @default(cuid())
  dailyUpdateId String
  text          String
  statusId      String?
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  dailyUpdate   DailyUpdate @relation(fields: [dailyUpdateId], references: [id], onDelete: Cascade)
  taskStatus    TaskStatus? @relation(fields: [statusId], references: [id])
  subTasks      SubTask[]

  @@index([dailyUpdateId])
  @@index([statusId])
  @@map("daily_tasks")
}

model TaskStatus {
  id        String      @id @default(cuid())
  label     String      @unique
  color     String      @default("#6366f1")
  sortOrder Int         @default(0)
  isDefault Boolean     @default(false)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())

  tasks     DailyTask[]

  @@map("task_statuses")
}

model SubTask {
  id          String    @id @default(cuid())
  dailyTaskId String
  text        String
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  dailyTask   DailyTask @relation(fields: [dailyTaskId], references: [id], onDelete: Cascade)

  @@index([dailyTaskId])
  @@map("sub_tasks")
}

model AdminNote {
  id            String      @id @default(cuid())
  dailyUpdateId String
  note          String
  createdById   String
  createdAt     DateTime    @default(now())

  dailyUpdate   DailyUpdate @relation(fields: [dailyUpdateId], references: [id], onDelete: Cascade)
  createdBy     User        @relation("AdminNoteCreator", fields: [createdById], references: [id])

  @@index([dailyUpdateId])
  @@map("admin_notes")
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("system_settings")
}

model Attendance {
  id        String           @id @default(cuid())
  userId    String
  date      DateTime         @db.Date
  status    AttendanceStatus @default(PRESENT)
  reason    String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@index([userId])
  @@map("attendances")
}

model LockedDate {
  id     String   @id @default(cuid())
  date   DateTime @unique @db.Date
  lockedAt DateTime @default(now())
  lockedById String

  @@map("locked_dates")
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entity      String
  entityId    String?
  details     String?  @db.Text
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([entity])
  @@map("activity_logs")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  message     String
  type        String   @default("info")
  isRead      Boolean  @default(false)
  link        String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}
